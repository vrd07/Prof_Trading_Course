{
  "name": "@trading-course/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "node --env-file=../../.env ./scripts/seed.mjs",
    "generate-types": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_REF\" --schema public > ../types/src/database.ts"
  },
  "dependencies": {
    "@trading-course/types": "workspace:*",
    "@supabase/supabase-js": "^2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}

